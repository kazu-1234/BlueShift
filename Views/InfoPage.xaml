<Page
    x:Class="App1.Views.InfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:views="using:App1.Views"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">
    <views:PageScrollHost>
        <Grid x:Name="ContentArea">
            <StackPanel Style="{StaticResource PageBaseStackPanelStyle}">
                <TextBlock x:Uid="Page_Info" Style="{StaticResource PageTitleTextStyle}" />

                <TextBlock x:Uid="Info_SectionUpdate" Style="{StaticResource SettingsSectionHeaderFirstStyle}" />

                <controls:SettingsCard>
                    <controls:SettingsCard.Header>
                        <StackPanel Spacing="4" MinWidth="0">
                            <TextBlock x:Name="VersionText" Style="{StaticResource CardHeaderTextStyle}" />
                            <TextBlock x:Uid="Info_UpdateDesc" Style="{StaticResource CardDescriptionTextStyle}" />
                        </StackPanel>
                    </controls:SettingsCard.Header>
                    <Button x:Name="CheckUpdateButton"
                            x:Uid="Info_CheckUpdate"
                            Click="CheckUpdateButton_Click" />
                </controls:SettingsCard>

                <InfoBar x:Name="UpdateInfoBar"
                         IsOpen="False"
                         IsClosable="True"
                         Severity="Informational"
                         HorizontalAlignment="Stretch" />

                <TextBlock x:Uid="Info_SectionStatus" Style="{StaticResource SettingsSectionHeaderStyle}" />
                <controls:SettingsCard>
                    <controls:SettingsCard.Description>
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="120" />
                                    <ColumnDefinition Width="*" MinWidth="0" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock x:Uid="Info_Feature" Opacity="0.7" />
                                <TextBlock x:Name="FilterStatusText" Grid.Column="1" FontWeight="SemiBold" />

                                <TextBlock Grid.Row="1" x:Uid="Info_Intensity" Opacity="0.7" />
                                <TextBlock x:Name="IntensityStatusText" Grid.Row="1" Grid.Column="1" FontWeight="SemiBold" />

                                <TextBlock Grid.Row="2" x:Uid="Info_ColorTemperature" Opacity="0.7" />
                                <TextBlock x:Name="ColorTemperatureStatusText" Grid.Row="2" Grid.Column="1" FontWeight="SemiBold" />

                                <TextBlock Grid.Row="3" x:Uid="Info_Schedule" Opacity="0.7" />
                                <TextBlock x:Name="ScheduleStatusText" Grid.Row="3" Grid.Column="1" FontWeight="SemiBold" TextWrapping="Wrap" />

                                <TextBlock Grid.Row="4" x:Uid="Info_NextTransition" Opacity="0.7" />
                                <TextBlock x:Name="NextTransitionStatusText" Grid.Row="4" Grid.Column="1" FontWeight="SemiBold" />
                            </Grid>

                            <InfoBar x:Name="DetailInfoBar"
                                     IsOpen="False"
                                     IsClosable="False"
                                     Severity="Informational"
                                     HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </controls:SettingsCard.Description>
                </controls:SettingsCard>

                <TextBlock x:Uid="Info_SectionDisclaimer" Style="{StaticResource SettingsSectionHeaderStyle}" />
                <controls:SettingsCard>
                    <controls:SettingsCard.Description>
                        <StackPanel Spacing="8">
                            <TextBlock x:Uid="Info_Description" Style="{StaticResource CardDescriptionTextStyle}" />
                            <TextBlock x:Uid="Info_Disclaimer" TextWrapping="Wrap" Opacity="0.75" FontSize="12" />
                        </StackPanel>
                    </controls:SettingsCard.Description>
                </controls:SettingsCard>
            </StackPanel>
        </Grid>
    </views:PageScrollHost>
</Page>
