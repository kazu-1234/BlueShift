<Page
    x:Class="App1.Views.InfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:views="using:App1.Views"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">
    <views:PageScrollHost>
        <Grid x:Name="ContentArea">
            <StackPanel Style="{StaticResource PageBaseStackPanelStyle}">
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <FontIcon Glyph="&#xE706;"
                              FontSize="48"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                    <StackPanel Spacing="4" VerticalAlignment="Center">
                        <TextBlock x:Uid="Info_AppName" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock x:Name="VersionCaptionText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Opacity="0.7" />
                    </StackPanel>
                </StackPanel>

                <TextBlock x:Uid="Info_SectionStatus" Style="{StaticResource SettingsSectionHeaderStyle}" />
                <controls:SettingsCard>
                    <controls:SettingsCard.Description>
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="120" />
                                    <ColumnDefinition Width="*" MinWidth="0" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock x:Uid="Info_Feature" Opacity="0.7" />
                                <TextBlock x:Name="FilterStatusText" Grid.Column="1" FontWeight="SemiBold" />

                                <TextBlock Grid.Row="1" x:Uid="Info_Intensity" Opacity="0.7" />
                                <TextBlock x:Name="IntensityStatusText" Grid.Row="1" Grid.Column="1" FontWeight="SemiBold" />

                                <TextBlock Grid.Row="2" x:Uid="Info_Schedule" Opacity="0.7" />
                                <TextBlock x:Name="ScheduleStatusText" Grid.Row="2" Grid.Column="1" FontWeight="SemiBold" TextWrapping="Wrap" />

                                <TextBlock Grid.Row="3" x:Uid="Info_NextTransition" Opacity="0.7" />
                                <TextBlock x:Name="NextTransitionStatusText" Grid.Row="3" Grid.Column="1" FontWeight="SemiBold" />
                            </Grid>

                            <InfoBar x:Name="DetailInfoBar"
                                     IsOpen="False"
                                     IsClosable="False"
                                     Severity="Informational"
                                     HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </controls:SettingsCard.Description>
                </controls:SettingsCard>

                <TextBlock x:Uid="Info_SectionAbout" Style="{StaticResource SettingsSectionHeaderStyle}" />
                <controls:SettingsCard>
                    <controls:SettingsCard.Description>
                        <StackPanel Spacing="8">
                            <TextBlock x:Uid="Info_Description" TextWrapping="Wrap" Opacity="0.8" />
                            <TextBlock x:Uid="Info_Disclaimer" TextWrapping="Wrap" Opacity="0.6" FontSize="12" />
                        </StackPanel>
                    </controls:SettingsCard.Description>
                </controls:SettingsCard>
            </StackPanel>
        </Grid>
    </views:PageScrollHost>
</Page>
